# Production Environment Configuration
# Use this as a template for production deployments
# NEVER commit actual secrets - these should be set via your deployment platform

# Database
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/legal-ai

# Authentication
NEXTAUTH_URL=https://legalai.yourdomain.com
NEXTAUTH_SECRET=your-generated-secret-key-here

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Services
OPENAI_API_KEY=sk-proj-your-openai-key
PINECONE_API_KEY=pcsk_your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=legal-docs

# Groq API (Legacy, if used)
GROQ_API_KEY=gsk_your-groq-key

# Email Service
EMAIL_USER=noreply@legalai.com
EMAIL_PASS=your-email-app-password

# Optional: Additional Security
ENCRYPTION_KEY=your-encryption-key
API_RATE_LIMIT=100